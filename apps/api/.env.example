PORT=3001
JWT_SECRET=super_secret_jwt_key_change_me_in_production

# Store Database (PostgreSQL)
DATABASE_URL="postgresql://nexus:nexus_dev_password@localhost:5434/nexus_store_db"

# Raffle Database & Feature Flag
RAFFLE_ENABLED=true
RAFFLE_DATABASE_URL="postgresql://nexus:nexus_dev_password@localhost:5433/nexus_raffle_db"

# BullMQ Redis
REDIS_URL="redis://localhost:6379"

# Mercado Pago embedded checkout (the Public Key is safe to expose to the browser)
MP_PUBLIC_KEY="APP_USR-your-public-key"
MP_EMBEDDED_CHECKOUT_ENABLED=true
# Límite interno antes de cancelar un pago que Mercado Pago no ha resuelto.
MP_PAYMENT_PROCESSING_MAX_MINUTES=120
