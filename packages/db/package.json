{
  "name": "@nexus/db",
  "version": "0.0.0",
  "private": true,
  "main": "src/index.ts",
  "exports": {
    "./store": {
      "types": "./src/store.ts",
      "default": "./src/store.ts"
    },
    "./raffle": {
      "types": "./src/raffle.ts",
      "default": "./src/raffle.ts"
    }
  },
  "typesVersions": {
    "*": {
      "store": ["./src/store.ts"],
      "raffle": ["./src/raffle.ts"]
    }
  },
  "scripts": {
    "generate": "pnpm generate:store && pnpm generate:raffle",
    "generate:store": "prisma generate --schema=prisma/store/schema.prisma",
    "generate:raffle": "prisma generate --schema=prisma/raffle/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^5.13.0"
  },
  "devDependencies": {
    "prisma": "^5.13.0",
    "typescript": "^5.4.5"
  }
}
