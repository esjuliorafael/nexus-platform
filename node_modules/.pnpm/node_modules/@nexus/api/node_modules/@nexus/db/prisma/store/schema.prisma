generator client {
  provider = "prisma-client-js"
  output   = "../../../../node_modules/@prisma/client-store"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Decision #7: Unified Settings Table
model Setting {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  value       String?
  description String?
  group       String   @default("general")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("settings")
}

model User {
  id                    Int      @id @default(autoincrement())
  username              String   @unique
  passwordHash          String   @map("password_hash")
  name                  String
  email                 String?
  role                  Role     @default(STAFF)
  receiveNotifications  Boolean  @default(true) @map("recibir_notificaciones")
  notificationEmail     String?  @map("email_notificaciones")
  createdAt             DateTime @default(now()) @map("fecha_creacion")
  active                Boolean  @default(true) @map("activo")

  @@map("users")
}

enum Role {
  SUPERADMIN
  ADMIN
  STAFF
}

// Storefront & Core Models
model Category {
  id            Int           @id @default(autoincrement())
  name          String        @map("nombre")
  icon          String?       @map("icono")
  createdAt     DateTime      @default(now()) @map("fecha_creacion")
  active        Boolean       @default(true) @map("activo")
  subcategories Subcategory[]
  media         Media[]

  @@map("categories")
}

model Subcategory {
  id         Int      @id @default(autoincrement())
  categoryId Int      @map("categoria_id")
  name       String   @map("nombre")
  active     Boolean  @default(true) @map("activo")
  category   Category @relation(fields: [categoryId], references: [id])
  media      Media[]

  @@map("subcategories")
}

model Product {
  id            Int              @id @default(autoincrement())
  type          ProductType      @map("tipo")
  name          String           @map("nombre")
  description   String?          @map("descripcion")
  price         Decimal          @default(0.00) @map("precio")
  thumbnail     String?          @map("portada")
  stock         Int              @default(1)
  ringNumber    String?          @map("anillo")
  age           String?          @map("edad")
  purpose       String?          @map("proposito")
  saleStatus    SaleStatus       @default(AVAILABLE) @map("estado_venta")
  active        Boolean          @default(true) @map("activo")
  createdAt     DateTime         @default(now()) @map("fecha_creacion")
  updatedAt     DateTime         @updatedAt @map("fecha_actualizacion")
  gallery       ProductGallery[]
  orderItems    OrderItem[]

  @@map("products")
}

enum ProductType {
  ARTICLE @map("articulo")
  BIRD    @map("ave")
}

enum SaleStatus {
  AVAILABLE @map("disponible")
  RESERVED  @map("reservado")
  SOLD      @map("vendido")
}

model ProductGallery {
  id        Int       @id @default(autoincrement())
  productId Int       @map("producto_id")
  filePath  String    @map("ruta_archivo")
  fileType  MediaType @default(PHOTO) @map("tipo_archivo")
  createdAt DateTime  @default(now()) @map("fecha_subida")
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_gallery")
}

model Order {
  id              Int           @id @default(autoincrement())
  customerName    String        @map("cliente_nombre")
  customerPhone   String        @map("cliente_telefono")
  shippingAddress String?       @map("direccion_envio")
  shippingState   String?       @map("estado_envio")
  deliveryType    DeliveryType  @default(SHIPPING) @map("tipo_entrega")
  subtotal        Decimal
  shippingCost    Decimal       @map("costo_envio")
  total           Decimal
  status          OrderStatus   @default(PENDING) @map("estatus")
  createdAt       DateTime      @default(now()) @map("fecha_creacion")
  items           OrderItem[]

  @@map("orders")
}

enum DeliveryType {
  SHIPPING @map("envio")
  PICKUP   @map("recoger")
}

enum OrderStatus {
  PENDING   @map("pendiente")
  PAID      @map("pagado")
  SHIPPED   @map("enviado")
  DELIVERED @map("entregado")
  CANCELLED @map("cancelado")
}

model OrderItem {
  id            Int         @id @default(autoincrement())
  orderId       Int         @map("orden_id")
  productId     Int         @map("producto_id")
  productName   String?     @map("nombre_producto")
  productType   ProductType @map("tipo_producto")
  quantity      Int         @map("cantidad")
  unitPrice     Decimal     @map("precio_unitario")
  order         Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product       Product     @relation(fields: [productId], references: [id])

  @@map("order_items")
}

// Media & Utils
model Media {
  id             Int          @id @default(autoincrement())
  title          String       @map("titulo")
  description    String?      @map("descripcion")
  type           MediaType    @map("tipo")
  filePath       String       @map("ruta_archivo")
  categoryId     Int?         @map("categoria_id")
  subcategoryId  Int?         @map("subcategoria_id")
  location       String?      @map("ubicacion")
  mediaDate      DateTime?    @map("fecha_media")
  likes          Int          @default(0)
  active         Boolean      @default(true) @map("activo")
  createdAt      DateTime     @default(now()) @map("fecha_creacion")
  category       Category?    @relation(fields: [categoryId], references: [id])
  subcategory    Subcategory? @relation(fields: [subcategoryId], references: [id])

  @@map("media")
}

enum MediaType {
  PHOTO @map("foto")
  VIDEO @map("video")
}

model PaymentChannel {
  id           Int      @id @default(autoincrement())
  name         String   @map("nombre")
  purpose      String   @map("proposito")
  bank         String   @map("banco")
  beneficiary  String   @map("beneficiario")
  clabe        String?
  card         String?  @map("tarjeta")
  createdAt    DateTime @default(now()) @map("fecha_creacion")

  @@map("payment_channels")
}

model WhatsappChannel {
  id           Int      @id @default(autoincrement())
  name         String   @map("nombre")
  purpose      String   @map("proposito")
  phone        String   @map("telefono")
  template     String   @map("plantilla")
  active       Boolean  @default(true) @map("activo")
  createdAt    DateTime @default(now()) @map("fecha_creacion")

  @@map("whatsapp_channels")
}

model ShippingZone {
  id       Int          @id @default(autoincrement())
  state    String       @map("estado")
  zoneType ShippingType @default(NORMAL) @map("tipo_zona")

  @@map("shipping_zones")
}

enum ShippingType {
  NORMAL    @map("normal")
  EXTENDED  @map("extendida")
}

model ExtraCharge {
  id          Int      @id @default(autoincrement())
  concept     String   @map("concepto")
  amount      Decimal  @map("monto")
  isPaid      Boolean  @default(false) @map("pagado")
  chargeDate  DateTime @map("fecha_cargo")
  createdAt   DateTime @default(now()) @map("fecha_creacion")

  @@map("extra_charges")
}

model AnnualService {
  id             Int       @id @default(autoincrement())
  concept        String    @map("concepto")
  description    String?   @map("descripcion")
  amount         Decimal   @map("monto")
  isPaid         Boolean   @default(false) @map("pagado")
  contractDate   DateTime? @map("fecha_contrato")
  expirationDate DateTime? @map("fecha_vencimiento")
  iconType       String    @default("default") @map("tipo_icono")
  createdAt      DateTime  @default(now()) @map("fecha_creacion")

  @@map("annual_services")
}
